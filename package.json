{
  "name": "@stritti/vitepress-plugin-openspec",
  "version": "0.3.1",
  "description": "A VitePress plugin that integrates OpenSpec documentation into your VitePress site",
  "keywords": [
    "openspec",
    "plugin",
    "vite-plugin",
    "vitepress",
    "vitepress-plugin",
    "documentation",
    "api-docs"
  ],
  "license": "MIT",
  "author": "Stephan Strittmatter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stritti/vitepress-plugin-openspec.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vitepress": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitepress": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  }
}
{
  "name": "vitepress-plugin-openspec",
  "version": "0.1.0",
  "description": "A VitePress plugin that integrates OpenSpec documentation into your VitePress site",
  "keywords": [
    "openspec",
    "plugin",
    "vite-plugin",
    "vitepress",
    "vitepress-plugin",
    "documentation",
    "api-docs"
  ],
  "license": "MIT",
  "author": "Stephan Strittmatter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stritti/vitepress-plugin-openspec.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitepress": "^1.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vitepress": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitepress": {
      "optional": true
    }
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  }
}
